{
  "id": "benzene-eas-nitration-v1",
  "version": "1.0.0",
  "title": "Nitration of benzene",
  "subtitle": "Electrophilic substitution",
  "levelTags": ["9701", "first-year-organic"],
  "defaultMode": "exam-friendly",
  "display": {
    "preferredRenderer": "svg-2d",
    "show3D": false,
    "showResonanceByDefault": false,
    "theme": "interactive"
  },
  "reaction": {
    "overallEquation": "C6H6 + HNO3 -> C6H5NO2 + H2O",
    "conditions": ["concentrated HNO3", "concentrated H2SO4", "50-55 °C"],
    "keyIdea": "Benzene undergoes substitution rather than addition because aromaticity is restored in the final step."
  },
  "examChecklist": [
    "Electrophile identified as NO2+.",
    "Curly arrow starts from benzene pi electrons.",
    "Sigma complex / arenium ion shown with a positive charge.",
    "Deprotonation step shown.",
    "Aromaticity restored in the final product."
  ],
  "teacherNotes": {
    "examFriendly": [
      "Keep the default view simple and stepwise.",
      "Do not show multiple resonance forms in the default view.",
      "Make the positive charge clear in the sigma complex.",
      "Do not use 3D in the main mechanism."
    ],
    "extension": [
      "You may later add a toggle for resonance forms of the sigma complex.",
      "You may later add a small extension note on why NO2+ is electrophilic."
    ]
  },
